{
  "manifest_version": 3,
  "name": "Code Revision Tracker",
  "version": "1.0.0",
  "description": "Track coding practice and get spaced repetition reminders for revision.",
  "permissions": ["activeTab", "storage", "alarms", "tabs"],
  "host_permissions": ["https://revise.mrinal.dev/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
