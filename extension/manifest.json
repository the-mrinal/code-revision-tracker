{
  "manifest_version": 3,
  "name": "Revise",
  "version": "1.1.0",
  "description": "Track what you learn and get spaced repetition reminders for revision.",
  "permissions": ["activeTab", "storage", "alarms", "tabs"],
  "host_permissions": ["https://revise.mrinal.dev/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://revise.mrinal.dev/*"],
      "js": ["capture-tokens.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
